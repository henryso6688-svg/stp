# STP Framework Configuration
# Copy this file to .env and modify as needed

# ========================================
# STP Framework Settings
# ========================================

# Operation mode: 'api' for API server, 'example' for running example, empty for interactive
STP_MODE=api

# API Server Configuration
STP_PORT=3000
STP_HOST=0.0.0.0
STP_ENABLE_LOGGING=true
STP_STRICT_VALIDATION=false
STP_TIMEOUT=30000

# ========================================
# Database Configuration
# ========================================

# PostgreSQL Configuration
POSTGRES_HOST=stp-postgres
POSTGRES_PORT=5432
POSTGRES_DB=stp
POSTGRES_USER=stp_user
POSTGRES_PASSWORD=stp_password

# Redis Configuration
REDIS_HOST=stp-redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ========================================
# Ministry-specific Configuration
# ========================================

# Ministry of Personnel (吏部) - Service Discovery
PERSONNEL_LOAD_BALANCING_STRATEGY=round-robin
PERSONNEL_HEALTH_CHECK_INTERVAL=30000

# Ministry of Revenue (户部) - Billing
REVENUE_DEFAULT_RATE_API_CALL=0.01
REVENUE_DEFAULT_RATE_STORAGE_MB=0.001
REVENUE_DEFAULT_RATE_COMPUTE_SECOND=0.05

# Ministry of Rites (礼部) - Protocol
RITES_DEFAULT_PROTOCOL=REST
RITES_DEFAULT_CONTENT_TYPE=application/json

# Ministry of War (兵部) - Security
WAR_RATE_LIMIT_REQUESTS=100
WAR_RATE_LIMIT_WINDOW=60000  # 1 minute in milliseconds
WAR_BLOCK_DURATION=300000    # 5 minutes in milliseconds

# Ministry of Justice (刑部) - Audit
JUSTICE_AUDIT_RETENTION_DAYS=90
JUSTICE_COMPLIANCE_ENABLED=true

# Ministry of Works (工部) - Infrastructure
WORKS_CPU_POOL_CAPACITY=100
WORKS_MEMORY_POOL_CAPACITY=1024
WORKS_STORAGE_POOL_CAPACITY=10000
WORKS_NETWORK_POOL_CAPACITY=1000

# ========================================
# Logging Configuration
# ========================================

LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=/app/logs/stp.log

# ========================================
# External Services (Optional)
# ========================================

# External API Keys (if needed)
API_KEY=
SECRET_KEY=

# Monitoring
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# ========================================
# Deployment Configuration
# ========================================

NODE_ENV=production
TZ=UTC

# Admin Interface
ADMIN_PORT=8080
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123