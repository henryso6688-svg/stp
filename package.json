{
  "name": "stp",
  "version": "0.1.0",
  "description": "A software architecture framework inspired by the Three Departments and Six Ministries system of Tang Dynasty China",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build",
    "example": "ts-node examples/basic-usage.ts",
    "start": "npm run build && node dist/server.js",
    "server": "ts-node src/server.ts",
    "docker:build": "docker build -t stp-framework .",
    "docker:run": "docker run -p 3000:3000 --env-file .env stp-framework",
    "docker:compose": "docker-compose up -d",
    "docker:compose-down": "docker-compose down",
    "deploy:local": "npm run build && npm run start"
  },
  "keywords": [
    "architecture",
    "framework",
    "three-departments",
    "six-ministries",
    "chinese-history",
    "microservices"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/helmet": "^4.0.0",
    "@types/morgan": "^1.9.9"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0"
  }
}